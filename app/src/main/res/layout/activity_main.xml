<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="@drawable/background_gradient"
    tools:context="com.example.app.MainActivity">

    <Button
        android:id="@+id/b1"
        android:text="@string/message_nlong"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/cercular_btn"
        android:gravity="center" />

    <Button
        android:id="@+id/b2"
        android:text="@string/message_short"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_width="220dp"
        android:layout_height="50dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/style_btn"
        android:drawableEnd="@drawable/ic_message_black_24dp"
        android:paddingEnd="15dp"
        tools:ignore="RtlSymmetry" />
    <Button
        android:id="@+id/b3"
        android:text="@string/notification"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_width="220dp"
        android:layout_height="50dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/style_btn"
        android:drawableEnd="@drawable/ic_message_black_24dp"
        android:paddingEnd="15dp"
        tools:ignore="RtlSymmetry" />
    <Button
        android:id="@+id/b4"
        android:text="@string/alert_une_noption_ok"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_width="220dp"
        android:layout_height="50dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/style_btn"
        android:drawableStart="@drawable/ic_notifications_active_black_24dp"
        android:paddingStart="15dp"
        tools:ignore="RtlSymmetry" />

    <Button
        android:id="@+id/b5"
        android:text="@string/alert_a_trois_options_oui_annuler_non"
        android:textColor="#333333"
        android:textStyle="bold"
        android:textSize="12sp"
        android:layout_width="200dp"
        android:layout_height="80dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/style_btn"
        android:gravity="center" />

    <Button
        android:id="@+id/b6"
        android:text="@string/alert_a_deux_noptions_oui_annuler_net_cases_a_cocher"
        android:textColor="#333333"
        android:textStyle="bold"
        android:textSize="11sp"
        android:layout_width="240dp"
        android:layout_height="100dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/style_btn"
        android:drawableTop="@drawable/ic_dialpad_black_24dp"
        android:paddingTop="10dp"
        android:gravity="center" />

</LinearLayout>